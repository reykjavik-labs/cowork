{
	"$schema": "https://opencode.ai/config.json",
	"default_agent": "coworker",
	"agent": {
		"coworker": {
			"model": "deepseek/deepseek-v4-pro",
			"permission": {
				"edit": "allow",
				"write": "allow",
				"bash": {
					"*": "ask",
					"git add *": "allow",
					"git status *": "allow",
					"git log *": "allow",
					"git commit *": "allow",
					"git push *": "allow",
					"git branch *": "allow",
					"git checkout *": "allow",
					"git remote -v *": "allow",
					"git diff *": "allow",
					"gh pr list *": "allow",
					"gh pr create *": "allow",
					"gh pr edit *": "allow",
					"bun run lint *": "allow",
					"mkdir *": "ask",
					"cat *": "allow",
					"echo *": "allow"
				}
			}
		}
	}
}
