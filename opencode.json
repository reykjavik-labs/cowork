{
	"$schema": "https://opencode.ai/config.json",
	"default_agent": "coworker",
	"agent": {
		"coworker": {
			"model": "deepseek/deepseek-v4-pro",
			"permission": {
				"edit": "allow",
				"write": "allow",
				"bash": {
					"*": "ask",
					"git *": "allow",
					"gh pr list *": "allow",
					"gh pr create *": "allow",
					"gh pr edit *": "allow",
					"bun run lint *": "allow",
					"mkdir *": "allow"
				}
			}
		}
	}
}
