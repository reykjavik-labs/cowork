{
    "config": {
        "default": true,
        "MD013": false,
        "MD033": false,
        "MD042": false,
        "MD007": {
            "indent": 4
        },
        "MD036": false,
        "MD041": false,
        "MD040": false,
        "MD060": false
    },
    "globs": [
        "projects/**/*.md",
        "README.md"
    ],
    "ignores": [
        ".github/CODEOWNERS"
    ],
    "outputFormatters": [
        [
            "markdownlint-cli2-formatter-pretty"
        ]
    ]
}